# ── Jarvis Briefing configuration ──────────────────────────────────────────
# Copy this file to `.env` and fill in your keys. `.env` is git-ignored.
# Never commit real keys.

# ── LLM providers ───────────────────────────────────────────────────────────
# Three ways to run the curate/write stages. Pick one per stage:
#
#   ollama    → FREE + LOCAL. Runs a model on your own machine, no key, no bill.
#               Requires Ollama installed and running (see README).
#   anthropic → Best quality, ~a few $/month on prepaid API credits.
#   openai    → Optional swap; needs its own API credits (NOT your ChatGPT Plus).
#
# NOTE: A Claude Pro / ChatGPT Plus subscription does NOT work here — those are
# the chat apps, billed separately from the API. See README → Billing.

# For the free local path, leave these blank:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Which provider handles each LLM stage. Values: ollama | anthropic | openai
# For $0 cost, set both to "ollama".
CURATE_PROVIDER=ollama
WRITE_PROVIDER=ollama

# Model per stage. Override to swap models without touching code.
# Ollama examples:    llama3.1, llama3.2, qwen2.5, mistral  (must be `ollama pull`ed)
# Anthropic examples: claude-sonnet-5, claude-opus-4-8, claude-haiku-4-5-20251001
# OpenAI examples:    gpt-4o, gpt-4o-mini
CURATE_MODEL=llama3.1
WRITE_MODEL=llama3.1

# Local Ollama server address. Only used when a provider is "ollama".
OLLAMA_BASE_URL=http://localhost:11434

# ── Text-to-speech (ElevenLabs) ─────────────────────────────────────────────
# If ELEVENLABS_API_KEY is unset, the narrator falls back to the macOS `say`
# command (writes an .mp3 via afconvert), so the pipeline still runs on a Mac.
ELEVENLABS_API_KEY=
# Voice ID for a calm, JARVIS-like narrator. Find IDs in the ElevenLabs app.
ELEVENLABS_VOICE_ID=
# Model + output format are sensible defaults; override only if you need to.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# ── Briefing personalisation ────────────────────────────────────────────────
# Used in the intro line: "Good morning, {LISTENER_NAME}."
LISTENER_NAME=Kenneth
# IANA timezone used for the "It's [time]" intro and dated filenames.
BRIEFING_TIMEZONE=Europe/Copenhagen
