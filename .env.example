# ── Jarvis Briefing configuration ──────────────────────────────────────────
# Copy this file to `.env` and fill in your keys. `.env` is git-ignored.
# Never commit real keys.

# ── LLM providers ───────────────────────────────────────────────────────────
# Four ways to run the curate/write stages. Pick one per stage:
#
#   gemini    → FREE cloud tier. Best for cloud/GitHub Actions (no local machine
#               needed). Get a key at https://aistudio.google.com/apikey (no card).
#   ollama    → FREE + LOCAL. Runs a model on your own machine, no key, no bill.
#               Requires Ollama running locally (see README) + an always-on Mac.
#   anthropic → Best quality, ~a few $/month on prepaid API credits.
#   openai    → Optional swap; needs its own API credits (NOT your ChatGPT Plus).
#
# NOTE: A Claude Pro / ChatGPT Plus subscription does NOT work here — those are
# the chat apps, billed separately from the API. See README → Billing.

# Free cloud LLM key (Gemini). Leave others blank unless you use them.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Which provider handles each LLM stage. Values: gemini | groq | ollama | anthropic | openai
CURATE_PROVIDER=gemini
WRITE_PROVIDER=gemini

# Automatic fallback: if the primary provider fails (e.g. Gemini free-tier
# rate limit), the call is retried here. Only fires if GROQ_API_KEY is set —
# leave the key blank to disable fallback entirely. Groq is free, no card:
# https://console.groq.com/keys
GROQ_API_KEY=
FALLBACK_PROVIDER=groq
FALLBACK_MODEL=llama-3.3-70b-versatile

# Model per stage. Override to swap models without touching code.
# Gemini examples:    gemini-2.0-flash, gemini-1.5-flash  (free tier)
# Ollama examples:    llama3.1, llama3.2, qwen2.5, mistral  (must be `ollama pull`ed)
# Anthropic examples: claude-sonnet-5, claude-opus-4-8, claude-haiku-4-5-20251001
# OpenAI examples:    gpt-4o, gpt-4o-mini
CURATE_MODEL=gemini-2.0-flash
WRITE_MODEL=gemini-2.0-flash

# Local Ollama server address. Only used when a provider is "ollama".
OLLAMA_BASE_URL=http://localhost:11434

# ── Text-to-speech ──────────────────────────────────────────────────────────
# Which narrator to use: auto | elevenlabs | edge | say
#   auto       → try elevenlabs → edge → macOS say (first available)
#   edge       → FREE Microsoft Edge neural voices, no key, works in the cloud
#   say        → macOS `say` (offline, Mac only)
#   elevenlabs → paid, highest quality
TTS_PROVIDER=auto
# Free edge-tts voice — a calm British male, good JARVIS stand-in.
# Browse voices: `edge-tts --list-voices`
EDGE_TTS_VOICE=en-GB-RyanNeural

# ── ElevenLabs (optional, paid) ─────────────────────────────────────────────
ELEVENLABS_API_KEY=
# Voice ID for a calm, JARVIS-like narrator. Find IDs in the ElevenLabs app.
ELEVENLABS_VOICE_ID=
# Model + output format are sensible defaults; override only if you need to.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# ── Briefing personalisation ────────────────────────────────────────────────
# Used in the intro line: "Good morning, {LISTENER_NAME}."
LISTENER_NAME=Kenneth
# IANA timezone used for the "It's [time]" intro and dated filenames.
BRIEFING_TIMEZONE=Europe/Copenhagen
