# ── Jarvis Briefing configuration ──────────────────────────────────────────
# Copy this file to `.env` and fill in your keys. `.env` is git-ignored.
# Never commit real keys.

# ── LLM providers ───────────────────────────────────────────────────────────
# Anthropic is the default and only required provider.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI is an OPTIONAL swap. Leave blank unless you switch a stage to openai.
OPENAI_API_KEY=

# Which provider handles each LLM stage. Values: anthropic | openai
# Defaults keep everything on Anthropic.
CURATE_PROVIDER=anthropic
WRITE_PROVIDER=anthropic

# Model per stage. Override to swap models without touching code.
# Anthropic examples: claude-sonnet-5, claude-opus-4-8, claude-haiku-4-5-20251001
# OpenAI examples:    gpt-4o, gpt-4o-mini
CURATE_MODEL=claude-sonnet-5
WRITE_MODEL=claude-sonnet-5

# ── Text-to-speech (ElevenLabs) ─────────────────────────────────────────────
# If ELEVENLABS_API_KEY is unset, the narrator falls back to the macOS `say`
# command (writes an .mp3 via afconvert), so the pipeline still runs on a Mac.
ELEVENLABS_API_KEY=
# Voice ID for a calm, JARVIS-like narrator. Find IDs in the ElevenLabs app.
ELEVENLABS_VOICE_ID=
# Model + output format are sensible defaults; override only if you need to.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# ── Briefing personalisation ────────────────────────────────────────────────
# Used in the intro line: "Good morning, {LISTENER_NAME}."
LISTENER_NAME=Kenneth
# IANA timezone used for the "It's [time]" intro and dated filenames.
BRIEFING_TIMEZONE=Europe/Copenhagen
